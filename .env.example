# ─────────────────────────────────────────────
# AI Job Search Agent — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Recommended: gpt-4o for best quality (most cost-effective for this use case)
OPENAI_API_KEY=sk-...

# Optional: Anthropic fallback
ANTHROPIC_API_KEY=sk-ant-...

# ── Job Discovery APIs ─────────────────────────

# Adzuna — free tier: 250 calls/month (register at developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Hiring Manager Enrichment ──────────────────

# Hunter.io — free tier: 25 searches/month (hunter.io/api)
HUNTER_API_KEY=

# ── Email Delivery ─────────────────────────────

# Option A: Gmail SMTP (recommended for personal use)
# Use an App Password (not your real password): myaccount.google.com/apppasswords
SENDER_EMAIL=your.gmail@gmail.com
SENDER_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Option B: SendGrid (recommended for reliability)
USE_SENDGRID=false
SENDGRID_API_KEY=SG....

# Where to send job reports
RECIPIENT_EMAIL=varshitmanepalli1810@gmail.com

# ── Debug ─────────────────────────────────────
DEBUG=false
